# ==============================================================================
# Django
# ==============================================================================

*.log
local_settings.py
db.sqlite3
db.sqlite3-journal


# ==============================================================================
# Django - Arquivos de mídia e configuração local
# ==============================================================================

media/
configuration/


# ==============================================================================
# Django - Static files coletados e logs
# ==============================================================================

staticfiles/
logs/

# IMPORTANTE:
# No projeto GLOT, os arquivos CSS/JS editáveis ficam em:
# base/static/
#
# A pasta static/ é usada como destino do collectstatic:
# python manage.py collectstatic
#
# Por isso, em regra, static/ não deve ser editada manualmente.

# Se em produção você usa static/ apenas como saída do collectstatic,
# mantenha esta linha ativa:
static/
!base/static/
base/static/*
!base/static/css/
base/static/css/*
!base/static/css/tailwind.input.css
!base/static/css/tailwind.css

# documentos: estáticos-fonte do app são versionados (bundle TipTap vendorizado
# + JS/CSS do editor). O collectstatic os copia para static/ na build/deploy.
!documentos/static/

# Se algum dia você decidir versionar static/ manualmente,
# comente a linha acima.


