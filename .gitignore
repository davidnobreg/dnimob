# ==============================================================================
# DN Imob - .gitignore
# Projeto Django + Tailwind CSS
# ==============================================================================


# ==============================================================================
# IDEs / Editores
# ==============================================================================

.idea/
.vscode/
*.sublime-project
*.sublime-workspace


# ==============================================================================
# Python - Bytecode / Cache
# ==============================================================================

__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd


# ==============================================================================
# Python - Ambientes virtuais
# ==============================================================================

.venv/
venv/
env/
ENV/
env.bak/
venv.bak/


# ==============================================================================
# Python - Build / Distribuição / Pacotes
# ==============================================================================

.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST


# ==============================================================================
# Python - Testes / Coverage / Cache
# ==============================================================================

htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/


# ==============================================================================
# Django
# ==============================================================================

*.log
local_settings.py
db.sqlite3
db.sqlite3-journal


# ==============================================================================
# Django - Arquivos de mídia e configuração local
# ==============================================================================

media/
configuration/


# ==============================================================================
# Django - Static files coletados e logs
# ==============================================================================

staticfiles/
logs/

# static/ é usada como destino do collectstatic:
# python manage.py collectstatic
static/


# ==============================================================================
# Node / Tailwind CSS
# ==============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/


# ==============================================================================
# Arquivos de ambiente / Secrets
# ==============================================================================

.env
.env.*
.envDnimob
!.env.example
!.envDnimob.example


# ==============================================================================
# Pipenv / Poetry
# ==============================================================================

Pipfile
Pipfile.lock
poetry.lock


# ==============================================================================
# Celery
# ==============================================================================

celerybeat-schedule
celerybeat.pid


# ==============================================================================
# Logs de instalação
# ==============================================================================

pip-log.txt
pip-delete-this-directory.txt


# ==============================================================================
