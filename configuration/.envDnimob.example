SECRET_KEY=substitua-por-chave-segura
ALLOWED_HOSTS=
DEBUG=False

# Banco de dados (PostgreSQL externo)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Redis / Celery
REDIS_URL=

# EMAIL — Resend SMTP relay
# Em dev: deixe EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Em prod: smtp.EmailBackend + credenciais Resend abaixo
EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_SSL=
EMAIL_USE_TLS=
DEFAULT_FROM_EMAIL=

# Evolution API (WhatsApp)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_TOKEN=

# Sicredi
SICREDI_API_URL=
SICREDI_TOKEN_URL=
SICREDI_WEBHOOK_SECRET=

# Asaas — assinatura interna (DN Software cobra a imobiliária pelo plano).
# Placeholders: ainda não existe conta/API key. Não confundir com a futura
# integração Asaas por-tenant do menu Boleto (chave diferente, por tenant).
# Prefixo da key identifica o ambiente: sandbox=$aact_hmlg_..., prod=$aact_prod_...
ASAAS_API_URL=
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# Sentry (prod) — deixe vazio em dev; preencha em prod para capturar erros
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_RATE=

# S3 / storage (prod)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_CUSTOM_DOMAIN=

# Backup (se AWS_BACKUP_BUCKET vazio, usa AWS_STORAGE_BUCKET_NAME + prefixo BACKUP_PREFIX)
AWS_BACKUP_BUCKET=
BACKUP_PREFIX=
PG_DUMP_PATH=/usr/bin/pg_dump

# Multi-tenant
BASE_DOMAIN=
SITE_BASE_URL=
